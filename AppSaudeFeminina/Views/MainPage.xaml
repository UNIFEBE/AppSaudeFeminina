<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppSaudeFeminina.MainPage"
             BackgroundColor="#FBF4EB">

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="20">

        <!-- Ícone estilizado -->
        <Border
            WidthRequest="96"
            HeightRequest="96"
            BackgroundColor="#FBD9E5"
            StrokeThickness="0"
            Rotation="12"
            StrokeShape="RoundRectangle 32"
            Shadow="{Shadow Brush=#C56682, Opacity=0.4, Radius=20, Offset='0,8'}">

            <Grid>
                <Image
                    Source="coracao_startup.png"
                    WidthRequest="80"
                    HeightRequest="80"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Grid>

        </Border>

        <Label
            Text="Minha Saúde&#10;Feminina"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"
            TextColor="#C43A4A"
            FontFamily="LeckerliOne" />

        <Label
            Text="Seu espaço inteligente de acompanhamento e saúde."
            FontSize="14"
            HorizontalTextAlignment="Center"
            TextColor="#9E9E9E" />

        <Button
            Text="CRIAR CONTA"
            BackgroundColor="#C43A4A"
            TextColor="White"
            CornerRadius="25"
            HeightRequest="50"
            WidthRequest="350"
            Clicked="OnCriarContaClicked" />

        <Button
            Text="ENTRAR"
            BackgroundColor="#FBF4EB"
            TextColor="#C43A4A"
            BorderColor="#C43A4A"
            BorderWidth="2"
            CornerRadius="25"
            HeightRequest="50"
            WidthRequest="350"
            Clicked="OnEntrarClicked" />

    </VerticalStackLayout>

</ContentPage>
