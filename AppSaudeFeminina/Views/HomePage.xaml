<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppSaudeFeminina.HomePage"
             BackgroundColor="#F8FAFC">
    <!-- Fundo slate-50 -->

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Título Saudação -->
            <Label Text="{Binding NomeUsuario, StringFormat='Olá, {0}'}" 
                   FontSize="30" 
                   FontAttributes="Bold" 
                   TextColor="#4C1D95" />
            <!-- purple-900 -->

            <!-- Card: Status do Ciclo (Gradiente) -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="1,1">
                        <GradientStop Color="#EC4899" Offset="0.0" />
                        <!-- pink-500 -->
                        <GradientStop Color="#9333EA" Offset="1.0" />
                        <!-- purple-600 -->
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#FBCFE8" Offset="0,10" Radius="15" Opacity="0.8" />
                </Border.Shadow>
                <VerticalStackLayout Padding="24" Spacing="16">
                    <Label Text="Status do Ciclo" TextColor="#FCE7F3" FontSize="14" Opacity="0.9" />

                    <Label Text="{Binding DiaCiclo, StringFormat='Dia {0} do Ciclo'}" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold" />

                    <!-- Barra de Progresso Customizada -->
                    <Border StrokeShape="RoundRectangle 4" HeightRequest="8" BackgroundColor="#33FFFFFF" StrokeThickness="0" Margin="0,8,0,0">
                        <BoxView Color="White" WidthRequest="{Binding ProgressoLargura}" HorizontalOptions="Start" />
                    </Border>

                    <Label Text="{Binding FaseTexto}" TextColor="White" FontSize="14" Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Grid: Preventivo e Consulta -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                <!-- Card Preventivo -->
                <Border Grid.Column="0" StrokeShape="RoundRectangle 16" Stroke="#F3E8FF" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="#E2E8F0" Offset="0,4" Radius="8" Opacity="0.5" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="#EFF6FF" HeightRequest="40" WidthRequest="40" HorizontalOptions="Start" StrokeThickness="0">
                            <!-- Usando Emoji como fallback nativo para ícone ShieldCheck -->
                            
                            <Label Text="🛡️" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" />
                        </Border>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="PREVENTIVO" TextColor="#64748B" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label Text="{Binding InfoPreventivo}" TextColor="#1E293B" FontSize="14" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Card Consulta -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle 16" Stroke="#F3E8FF" StrokeThickness="1" BackgroundColor="White" Padding="16">
                    <Border.Shadow>
                        <Shadow Brush="#E2E8F0" Offset="0,4" Radius="8" Opacity="0.5" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FFF7ED" HeightRequest="40" WidthRequest="40" HorizontalOptions="Start" StrokeThickness="0">
                            <!-- Usando Emoji como fallback nativo para ícone Stethoscope -->
                            <Label Text="🩺" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" />
                        </Border>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="CONSULTA" TextColor="#64748B" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label Text="{Binding InfoConsulta}" TextColor="#1E293B" FontSize="14" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Card: Dica do Dia -->
            <Border StrokeShape="RoundRectangle 24" BackgroundColor="#FAF5FF" Stroke="#F3E8FF" StrokeThickness="1" Padding="24">
                <VerticalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="💡" FontSize="18" VerticalOptions="Center" />
                        <Label Text="Dica do Dia" TextColor="#581C87" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding DicaDoDia}" 
                           TextColor="#6B21A8" 
                           FontSize="14" 
                           FontAttributes="Italic" 
                           LineHeight="1.4" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>