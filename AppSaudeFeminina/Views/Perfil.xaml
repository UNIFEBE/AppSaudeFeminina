<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppSaudeFeminina.Views.Perfil"
             Title="Perfil"
             BackgroundColor="#FBF4EB">

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout VerticalOptions="Start">

                <Grid ColumnDefinitions="*, Auto" Padding="20">
                    <Label Grid.Column="0" 
                           Text="Meu Perfil" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           TextColor="#C43A4A" 
                           VerticalOptions="Center" 
                           HorizontalOptions="Start"
                           FontFamily="LeckerliOne" />

                    <ImageButton Grid.Column="1" 
                                 Source="engrenagem.svg"
                                 BackgroundColor="#FBD9E5" 
                                 CornerRadius="16" 
                                 HeightRequest="48" 
                                 WidthRequest="48" 
                                 Padding="12"
                                 VerticalOptions="Center"
                                 Clicked="OnSettingsClicked" />
                </Grid>

                <Border Margin="20,10,20,20"
                        Padding="0,40,0,40"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 32"
                        StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Brush="#E7A48C" Offset="0,4" Radius="15" Opacity="0.3" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Border HeightRequest="100" 
                                WidthRequest="100" 
                                StrokeShape="RoundRectangle 50" 
                                StrokeThickness="0" 
                                BackgroundColor="#FBD9E5"
                                HorizontalOptions="Center"
                                Margin="0,0,0,15">
                            <Image Source="avatar.svg" 
                                   HeightRequest="50" 
                                   WidthRequest="50" 
                                   VerticalOptions="Center" 
                                   HorizontalOptions="Center" />
                        </Border>
                        <Label Text="Usuária" FontSize="24" FontAttributes="Bold" TextColor="#C43A4A" HorizontalOptions="Center"/>
                        <Label Text="perfil@email.com" FontSize="16" TextColor="#8A95A5" FontAttributes="Bold" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="20,0,20,20">
                    <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 24" StrokeThickness="0" Padding="10,25,10,25">
                        <Border.Shadow>
                            <Shadow Brush="#E7A48C" Offset="0,4" Radius="10" Opacity="0.25" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="batimento.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                            <Label Text="PESO ATUAL" FontSize="12" FontAttributes="Bold" TextColor="#8A95A5" HorizontalOptions="Center" />
                            <Label Text="0kg" FontSize="22" FontAttributes="Bold" TextColor="#C43A4A" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" StrokeThickness="0" Padding="10,25,10,25">
                        <Border.Shadow>
                            <Shadow Brush="#E7A48C" Offset="0,4" Radius="10" Opacity="0.25" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Image Source="raio.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                            <Label Text="CICLO MÉDIO" FontSize="12" FontAttributes="Bold" TextColor="#8A95A5" HorizontalOptions="Center" />
                            <Label Text="28d" FontSize="22" FontAttributes="Bold" TextColor="#C43A4A" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <BoxView x:Name="OverlayEscuro" 
                 Grid.RowSpan="2"
                 BackgroundColor="#3A1A1A" 
                 Opacity="0" 
                 IsVisible="False"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="FecharModal_Clicked" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <Border x:Name="ModalOpcoes" 
                Grid.RowSpan="2"
                BackgroundColor="#FBF4EB" 
                VerticalOptions="End" 
                IsVisible="False"
                Padding="25,15,25,35"
                StrokeThickness="0"
                TranslationY="400">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="32,32,0,0" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">

                <BoxView HeightRequest="4" 
                         WidthRequest="40" 
                         CornerRadius="2" 
                         BackgroundColor="#FBD9E5" 
                         HorizontalOptions="Center" 
                         Margin="0,0,0,10"/>

                <Label Text="Opções do Perfil" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#C43A4A" 
                       Margin="0,0,0,10"/>

                <Button Text="EDITAR PERFIL" 
                        Clicked="CriarConta_Clicked"
                        FontAttributes="Bold"
                        BackgroundColor="#C43A4A" 
                        TextColor="White" 
                        CornerRadius="16" 
                        HeightRequest="56"/>

                <Button Text="SAIR DA CONTA" 
                        Clicked="SairDaConta_Clicked"
                        FontAttributes="Bold"
                        BackgroundColor="#FBD9E5" 
                        TextColor="#C43A4A" 
                        CornerRadius="16" 
                        HeightRequest="56"/>

                <Button Text="FECHAR" 
                        FontAttributes="Bold"
                        BackgroundColor="#FBF4EB" 
                        TextColor="#8A95A5" 
                        CornerRadius="16" 
                        HeightRequest="56"
                        Clicked="FecharModal_Clicked"/>

            </VerticalStackLayout>
        </Border>

        <!-- NavBar -->
        <Border Grid.Row="1" BackgroundColor="White" Padding="15,10,15,20"
                StrokeThickness="1" Stroke="#FBD9E5">
            <Border.Shadow>
                <Shadow Brush="#C56682" Offset="0,-4" Radius="10" Opacity="0.1" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, *, *, *">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4" Opacity="0.6">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHojeTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" Padding="8" StrokeThickness="0">
                        <Label Text="❤️" FontSize="20" HorizontalOptions="Center" />
                    </Border>
                    <Label Text="Hoje" FontSize="10" TextColor="#64748B" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4" Opacity="0.6">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCicloTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" Padding="8" StrokeThickness="0">
                        <Label Text="📅" FontSize="20" HorizontalOptions="Center" />
                    </Border>
                    <Label Text="Ciclo" FontSize="10" TextColor="#64748B" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4" Opacity="0.6">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnConteudosTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" Padding="8" StrokeThickness="0">
                        <Label Text="📖" FontSize="20" HorizontalOptions="Center" />
                    </Border>
                    <Label Text="Conteúdos" FontSize="10" TextColor="#64748B" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <Border StrokeShape="RoundRectangle 8" BackgroundColor="#FBD9E5" Padding="8" StrokeThickness="0">
                        <Label Text="👤" FontSize="20" HorizontalOptions="Center" />
                    </Border>
                    <Label Text="Perfil" FontSize="10" TextColor="#C43A4A" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
